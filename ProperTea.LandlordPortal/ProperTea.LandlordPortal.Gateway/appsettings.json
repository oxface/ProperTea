{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "organization-create": {
        "ClusterId": "organizationCluster",
        "Match": { "Path": "/organization", "Methods": [ "POST" ] },
        "AuthorizationPolicy": "AllowAnonymous"
      },
      "organization": {
        "ClusterId": "organizationCluster",
        "Match": { "Path": "/organization/{**catch-all}" }
      },
      "system-user": {
        "ClusterId": "systemUserCluster",
        "Match": { "Path": "/system-user/{**catch-all}" }
      },
      "company": {
        "ClusterId": "companyCluster",
        "Match": { "Path": "/company/{**catch-all}" }
      }
    }
  }
}
